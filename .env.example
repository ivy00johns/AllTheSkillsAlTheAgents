# AllTheSkillsAllTheAgents — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env
#
# This is the single source of truth for all skill credentials.
# Skills read from this root .env — do NOT create per-skill .env files.

# ──────────────────────────────────────────────
# Nano Banana (Gemini Image Generation)
# Get key: https://aistudio.google.com/apikey
# ──────────────────────────────────────────────
GEMINI_API_KEY=

# ──────────────────────────────────────────────
# Railway Deployment
# Get token: https://railway.app/account/tokens
# Get IDs from Railway project dashboard URLs
# ──────────────────────────────────────────────
RAILWAY_API_TOKEN=
RAILWAY_PROJECT_ID=
RAILWAY_DEV_ENV_ID=
RAILWAY_PROD_ENV_ID=
RAILWAY_DEV_SERVICE_ID=
RAILWAY_PROD_SERVICE_ID=
# Optional: worker services
# RAILWAY_DEV_WORKER_SERVICE_ID=
# RAILWAY_PROD_WORKER_SERVICE_ID=
