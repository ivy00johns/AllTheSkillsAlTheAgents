{
  "name": "@future/platform",
  "private": true,
  "version": "0.1.0",
  "description": "Greenfield platform workspace for the future software factory.",
  "scripts": {
    "check:prereqs": "bash scripts/check-prereqs.sh",
    "infra:up": "docker compose -f infra/compose.local.yml up -d",
    "infra:down": "docker compose -f infra/compose.local.yml down",
    "infra:logs": "docker compose -f infra/compose.local.yml logs -f",
    "validate:schemas": "node scripts/validate-schemas.mjs"
  }
}
