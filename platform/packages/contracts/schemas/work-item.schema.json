{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "future.work-item",
  "title": "WorkItem",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "project_id",
    "kind",
    "title",
    "status",
    "priority",
    "created_at"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "mission_id": { "type": "string" },
    "parent_id": { "type": "string" },
    "kind": {
      "type": "string",
      "enum": ["task", "bug", "finding", "decision", "gate", "escalation"]
    },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["queued", "ready", "in_progress", "blocked", "completed", "rejected"]
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4
    },
    "labels": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "depends_on": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "evidence_ids": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
