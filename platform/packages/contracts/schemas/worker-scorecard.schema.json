{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "future.worker-scorecard",
  "title": "WorkerScorecard",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "worker_profile_id",
    "review_precision",
    "qa_catch_rate",
    "merge_success_rate",
    "updated_at"
  ],
  "properties": {
    "worker_profile_id": { "type": "string", "minLength": 1 },
    "review_precision": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "qa_catch_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "merge_success_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "mean_cost_usd": {
      "type": "number",
      "minimum": 0
    },
    "mean_duration_seconds": {
      "type": "number",
      "minimum": 0
    },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
