{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "qa-report-schema",
  "title": "QE Agent QA Report",
  "description": "Structured QA report output by the QE agent. The orchestrator's TaskCompleted hook parses this to gate build completion.",
  "type": "object",
  "required": ["schema_version", "timestamp", "agent_role", "build_session_id", "status", "scores", "test_results", "blockers", "issues", "recommendations", "gate_decision"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "timestamp": { "type": "string", "format": "date-time" },
    "agent_role": { "type": "string", "const": "qe" },
    "build_session_id": { "type": "string" },
    "status": { "type": "string", "enum": ["PASS", "FAIL", "PARTIAL", "BLOCKED"] },
    "scores": {
      "type": "object",
      "required": ["correctness", "completeness", "code_quality", "security", "contract_conformance"],
      "properties": {
        "correctness": { "$ref": "#/$defs/ScoreEntry" },
        "completeness": { "$ref": "#/$defs/ScoreEntry" },
        "code_quality": { "$ref": "#/$defs/ScoreEntry" },
        "security": { "$ref": "#/$defs/ScoreEntry" },
        "contract_conformance": { "$ref": "#/$defs/ScoreEntry" }
      }
    },
    "test_results": {
      "type": "object",
      "required": ["unit", "integration", "e2e", "contract", "security_scan"],
      "properties": {
        "unit": { "$ref": "#/$defs/TestCounts" },
        "integration": { "$ref": "#/$defs/TestCounts" },
        "e2e": { "$ref": "#/$defs/TestCounts" },
        "contract": { "$ref": "#/$defs/TestCounts" },
        "security_scan": { "$ref": "#/$defs/TestCounts" }
      }
    },
    "blockers": { "type": "array", "items": { "$ref": "#/$defs/Blocker" } },
    "issues": { "type": "array", "items": { "$ref": "#/$defs/Issue" } },
    "recommendations": { "type": "array", "items": { "type": "string" } },
    "gate_decision": {
      "type": "object",
      "required": ["proceed", "reason"],
      "properties": {
        "proceed": { "type": "boolean" },
        "reason": { "type": "string" }
      }
    }
  },
  "$defs": {
    "ScoreEntry": {
      "type": "object",
      "required": ["score", "notes"],
      "properties": {
        "score": { "type": "integer", "minimum": 1, "maximum": 5 },
        "notes": { "type": "string" }
      }
    },
    "TestCounts": {
      "type": "object",
      "required": ["pass", "fail", "skip"],
      "properties": {
        "pass": { "type": "integer", "minimum": 0 },
        "fail": { "type": "integer", "minimum": 0 },
        "skip": { "type": "integer", "minimum": 0 }
      }
    },
    "Blocker": {
      "type": "object",
      "required": ["id", "severity", "category", "description", "suggested_fix"],
      "properties": {
        "id": { "type": "string" },
        "severity": { "type": "string", "enum": ["CRITICAL", "HIGH"] },
        "category": { "type": "string", "enum": ["contract_violation", "security", "build_failure", "test_failure", "other"] },
        "file": { "type": ["string", "null"] },
        "line": { "type": ["integer", "null"] },
        "description": { "type": "string" },
        "suggested_fix": { "type": "string" }
      }
    },
    "Issue": {
      "type": "object",
      "required": ["id", "severity", "category", "description", "suggested_fix"],
      "properties": {
        "id": { "type": "string" },
        "severity": { "type": "string", "enum": ["MEDIUM", "LOW", "INFO"] },
        "category": { "type": "string" },
        "file": { "type": ["string", "null"] },
        "line": { "type": ["integer", "null"] },
        "description": { "type": "string" },
        "suggested_fix": { "type": "string" }
      }
    }
  },
  "x-gate-rules": {
    "description": "Orchestrator sets gate_decision.proceed = false when any of these conditions are met",
    "conditions": [
      "status is FAIL or BLOCKED",
      "any blocker has severity CRITICAL",
      "scores.contract_conformance.score < 3",
      "scores.security.score < 3"
    ]
  }
}
